<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <stage id="scan" sequence="1" name="SCAN">
    <description>Scan all type definitions</description>
    <target>types/*</target>
    <command>tsc --noEmit</command>
    <fail-on-error>true</fail-on-error>
  </stage>
  
  <stage id="ast-check" sequence="2" name="AST_CHECK">
    <description>Check AST of core code</description>
    <target>core/*</target>
    <command>eslint src --ext .ts,.tsx</command>
    <fail-on-error>true</fail-on-error>
  </stage>
  
  <stage id="build" sequence="3" name="BUILD">
    <description>Compile TypeScript</description>
    <command>tsc</command>
    <output>dist/</output>
    <fail-on-error>true</fail-on-error>
  </stage>
  
  <stage id="test" sequence="4" name="TEST">
    <description>Run tests with coverage</description>
    <command>jest --coverage</command>
    <min-coverage>95</min-coverage>
    <fail-on-error>true</fail-on-error>
  </stage>
  
  <stage id="validate" sequence="5" name="VALIDATE">
    <description>Validate output</description>
    <checks>
      <check type="coverage" min="95" />
      <check type="lint-errors" max="0" />
      <check type="type-errors" max="0" />
    </checks>
    <fail-on-error>true</fail-on-error>
  </stage>
  
  <stage id="output" sequence="6" name="OUTPUT">
    <description>Generate artifacts</description>
    <artifacts>
      <artifact type="build" path="dist/" />
      <artifact type="types" path="dist/**/*.d.ts" />
      <artifact type="coverage" path="coverage/" />
    </artifacts>
  </stage>
  
  <environment>
    <variable name="NODE_ENV">production</variable>
    <variable name="STRICT_MODE">1</variable>
  </environment>
</pipeline>
